PORT=4242
APP_URL=http://localhost:4242
ADMIN_PASSWORD=change_this_to_a_strong_password

# Stripe keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
STRIPE_CURRENCY=usd
STRIPE_AUTOMATIC_TAX=true
# Optional fallback if you are not using Stripe Tax setup.
# Example 7.25 means 7.25% manual tax line item added at checkout.
MANUAL_SALES_TAX_RATE=0
# If true, manual sales tax applies to (items + shipping). If false, items only.
MANUAL_SALES_TAX_APPLY_TO_SHIPPING=false
# Manual tax is not charged for these states (comma-separated 2-letter codes).
MANUAL_NON_TAX_STATES=AK,DE,MT,NH,OR
ALLOWED_SHIPPING_COUNTRIES=US,CA
# Default per-item shipping fee used when shipping is enabled on a product
DEFAULT_SHIPPING_FEE=5.00
# USPS Ground Advantage estimate settings for checkout/cart shipping
# Optional minimum checkout shipping charge (set 0 for no floor)
SHIPPING_MIN_FEE=0.00
# Base package weight for first shippable unit
SHIPPING_BASE_WEIGHT_LBS=1.5
# Additional weight added for each extra unit after the first
SHIPPING_ADDITIONAL_WEIGHT_PER_UNIT_LBS=1.0
# USPS "Weight Not Over" tier prices in lbs:dollars (comma-separated, tier lookup)
USPS_GROUND_ADVANTAGE_RATE_TABLE=1.5:11.92,2:12.90,3:14.58,4:16.68,5:17.77,10:23.50
# Zone to use when state map has no match
USPS_DEFAULT_ZONE=8
# Zone scaling multipliers (based on screenshot/reference zone table)
USPS_GROUND_ADVANTAGE_ZONE_SCALE=1:0.7424,2:0.7718,3:0.7928,4:0.8221,5:0.8515,6:0.8809,7:0.9262,8:1
# State to zone map (2-letter state code to zone number)
USPS_STATE_ZONE_MAP=NY:1,CT:2,NJ:2,PA:2,MA:2,RI:2,VT:2,NH:2,DE:2,MD:2,DC:2,ME:3,VA:3,WV:3,OH:3,NC:3,SC:4,GA:4,TN:4,KY:4,IN:4,MI:4,IL:4,AL:5,FL:5,MS:5,WI:5,MN:5,IA:5,MO:5,AR:5,LA:5,ND:6,SD:6,NE:6,KS:6,OK:6,TX:6,NM:6,CO:6,WY:6,MT:7,ID:7,UT:7,AZ:7,NV:7,WA:8,OR:8,CA:8,AK:8,HI:8

# USPS Labels API (used by Admin -> Orders -> Create USPS Label)
# Use https://apis-tem.usps.com for USPS test credentials, https://apis.usps.com for production.
USPS_API_BASE_URL=https://apis-tem.usps.com
# Optional explicit overrides
# USPS_OAUTH_URL=https://apis-tem.usps.com/oauth2/v3/token
# USPS_PAYMENT_AUTH_URL=https://apis-tem.usps.com/payments/v3/payment-authorization
# USPS_LABEL_URL=https://apis-tem.usps.com/labels/v3/label
USPS_CLIENT_ID=your_usps_client_id
USPS_CLIENT_SECRET=your_usps_client_secret
USPS_CRID=your_crid
USPS_MID=your_mid
USPS_MANIFEST_MID=your_manifest_mid
USPS_ACCOUNT_TYPE=EPS
USPS_ACCOUNT_NUMBER=your_eps_account_number
USPS_FROM_NAME=PublisHearts Shipping
USPS_FROM_COMPANY=PublisHearts
USPS_FROM_ADDRESS1=123 Main St
USPS_FROM_ADDRESS2=Suite 1
USPS_FROM_CITY=New York
USPS_FROM_STATE=NY
USPS_FROM_ZIP5=10001
USPS_FROM_ZIP4=0001
# Optional label defaults
USPS_DEFAULT_MAIL_CLASS=USPS_GROUND_ADVANTAGE
USPS_DEFAULT_RATE_INDICATOR=SP
USPS_DEFAULT_PROCESSING_CATEGORY=MACHINABLE
USPS_DEFAULT_PKG_LENGTH_IN=9
USPS_DEFAULT_PKG_WIDTH_IN=6
USPS_DEFAULT_PKG_HEIGHT_IN=2
USPS_LABEL_IMAGE_TYPE=PDF
USPS_LABEL_TYPE=4X6LABEL

# Optional storage paths (use persistent disk paths in production if available)
# PRODUCTS_FILE=/var/data/products.json
# SITE_SETTINGS_FILE=/var/data/site-settings.json
# ADDRESS_BOOK_FILE=/var/data/address-book.json
# UPLOADS_DIR=/var/data/uploads

# Optional: publish live Admin changes back to GitHub
# Create a fine-grained token with repo contents write access
# GITHUB_PUSH_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
# GITHUB_REPO=PublisHearts/PublisHearts.com
# GITHUB_BRANCH=main
# GITHUB_AUTHOR_NAME=PublisHearts Admin Bot
# GITHUB_AUTHOR_EMAIL=admin@publishearts.com

# Where order notifications should be sent
OWNER_EMAIL=you@example.com

# SMTP provider (Brevo, Gmail app password, etc.)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=PublisHearts Orders <orders@publishearts.com>
